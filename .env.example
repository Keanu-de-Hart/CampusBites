# PayFast configuration. Sandbox defaults shown; swap to production via env vars only.
PAYFAST_HOST=https://sandbox.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn

# Public URLs PayFast redirects/notifies. Use your Vercel preview/prod URL or ngrok tunnel for local dev.
PAYFAST_RETURN_URL=https://your-domain.example/payment-success.html
PAYFAST_CANCEL_URL=https://your-domain.example/payment-cancel.html
PAYFAST_NOTIFY_URL=https://your-domain.example/api/payfast/itn

# Firebase service account (entire JSON, single line). Paste the contents of the file
# downloaded from Firebase Console > Project Settings > Service Accounts > Generate new private key.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
