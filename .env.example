# Paystack credentials. Use test keys (sk_test_…) in development; swap to live
# (sk_live_…) only via production env vars. Find these in the Paystack dashboard
# under Settings > API Keys & Webhooks.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where Paystack sends the customer after they finish (or cancel) the hosted
# checkout. Paystack appends ?reference=<ref>&trxref=<ref> to the URL.
PAYSTACK_CALLBACK_URL=https://campus-bites-zeta.vercel.app/payment-success.html

# Webhook URL is configured in the Paystack dashboard, not here. For reference:
# https://campus-bites-zeta.vercel.app/api/paystack/webhook

# Firebase service account (entire JSON, single line). Paste the contents of the
# file downloaded from Firebase Console > Project Settings > Service Accounts >
# Generate new private key.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
